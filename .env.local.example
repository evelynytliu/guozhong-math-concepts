# ─────────────────────────────────────────────────────────────
# 這個檔是「範本」。複製成 .env.local 後填入，才會生效。
# 全部留空也能跑：進度與解釋會存在瀏覽器 localStorage（本機自用足夠）。
# ─────────────────────────────────────────────────────────────

# ── Supabase（選用）──
# 填了這兩個，進度/解釋會改存到 Supabase；沒填就用 localStorage。
# 從 Supabase 專案 → Project Settings → API 取得。
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── 密碼門（選用）──
# 設了之後，要先輸入這個密碼才打得開網站（用來保護公開版）。
# 本機自己用可留空。公開版（GitHub Pages）的密碼設在 GitHub Secrets。
NEXT_PUBLIC_APP_PASSCODE=

# ── AI 環節（解釋判斷 / 草稿追問 / 章節診斷）──
# 改用 Gemini 免費 API。金鑰從 Google AI Studio 申請：
#   https://aistudio.google.com/apikey
# 填了才會啟用 AI；沒填會自動退回靜態模式（孩子不會卡住）。
GEMINI_API_KEY=

# 選填：指定模型（留空 = gemini-2.5-flash）。想更聰明、一樣免費可填 gemini-3-flash。
# 免費版 Flash 系列每天約 1,500 次，一個孩子綽綽有餘。
GEMINI_MODEL=

# ── 部署到雲端、iPad 隨地能用 ──
# 因為 AI 改走 Gemini 金鑰（不再是本機訂閱），整個網站含 API route 都可以部署到雲端
# （如 Vercel），孩子在阿嬤家用 iPad 直接開即可，家裡不用開電腦。
# 全部同源部署時，下面這個留空即可（AI 請求打同一個網域的 /api/...）。
NEXT_PUBLIC_AI_BASE_URL=

# 選填：收緊 AI route 的 CORS 允許來源（留空 = 允許所有來源）。
# 建議設成公開站來源，例如 https://evelynytliu.github.io
AI_ALLOWED_ORIGIN=
